# Copiá este archivo a uno llamado ".env" (sin ".example") y completá con
# la direccion de conexion de tu base de datos (por ejemplo, de Neon).
# Este archivo es SOLO para probar en tu compu; en Render esta variable
# se carga desde el panel de "Environment", no hace falta este archivo ahi.

DATABASE_URL=postgresql://usuario:contraseña@host/nombre_basedatos?sslmode=require
